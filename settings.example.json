{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(node --check:*)",
      "Bash(bash -n:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(brew install:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)"
    ]
  }
}
